{
  "name": "pinpoint-fe-v3",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "clean": "turbo run clean --force && rm -rf node_modules",
    "clean:dist": "turbo run clean:dist --force",
    "storybook": "turbo run storybook --force",
    "build:storybook": "turbo run build-storybook",
    "deploy:storybook": "turbo run chromatic"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "turbo": "^2.4.0"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=22.13.1"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {}
}
